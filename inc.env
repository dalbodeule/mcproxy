# mcproxy environment include file
# Usage (bash/zsh): set -a; source ./inc.env; set +a

# HTTP API bind address
MCPROXY_HTTP_ADDR=127.0.0.1:8080

# Admin API token (required for /api/v1/*)
# MCPROXY_ADMIN_TOKEN=change-me

# Database configuration
# Options: sqlite | postgres
MCPROXY_DB_DRIVER=sqlite
# SQLite file path (used when MCPROXY_DB_DRIVER=sqlite)
MCPROXY_SQLITE_PATH=data/mcproxy.db
# PostgreSQL DSN example (used when MCPROXY_DB_DRIVER=postgres)
# MCPROXY_POSTGRES_DSN=postgres://user:password@localhost:5432/mcproxy?sslmode=disable

# GeoLite2-City.mmdb path (optional)
# MCPROXY_GEOIP_PATH=data/GeoLite2-City.mmdb
